Options -Indexes

# ─── JSON Asset Caching ────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(json)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set Content-Type "application/json; charset=utf-8"
        Header set Access-Control-Allow-Origin "*"
        Header set ETag ""
        Header unset Last-Modified
    </FilesMatch>
</IfModule>
